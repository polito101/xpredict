# XPredict frontend — environment variables (example values only; no real secrets).
# Copy to .env.local (gitignored) and adjust per environment.

# --- Public (readable in the browser bundle — must be NEXT_PUBLIC_) ----------

# Live-bets widget script URL, loaded by next/script on /live (v1.3 Live-Bets demo).
# This is the LB-C local dev value; the widget.js is served from the live-bets
# origin (design §4 — served locally, no SRI in dev). Leave unset until LB-C is up;
# /live then renders a "Live widget not configured" notice instead of a broken script.
NEXT_PUBLIC_LIVEBETS_WIDGET_SRC=http://localhost:8080/static/widget.js

# Public backend base URL used by client-side fetches (e.g. price-history re-fetch,
# WS base). The browser cannot resolve a Docker-internal hostname, so this must be
# the host-reachable URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Server-only (NEVER prefixed NEXT_PUBLIC_; stays out of the client bundle) -

# Backend base URL for server-side fetches (Server Components + Server Actions:
# auth, bet placement, wallet balance, the live-bets mirror). In Docker this is the
# internal network address (e.g. http://backend:8000); falls back to localhost for
# host-run dev.
BACKEND_URL=http://localhost:8000
