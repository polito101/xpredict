{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File .claude/hooks/check-phase-ready.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File .claude/hooks/linear-to-review.ps1"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File .claude/hooks/linear-create-issue.ps1"
          }
        ]
      }
    ]
  }
}
