# Anthropic API key — used by notify-slack-pr.ps1 for AI PR summaries
ANTHROPIC_API_KEY=sk-ant-...

# Slack incoming webhook URL — post to channel #prs
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Linear API key — create at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# Linear team ID — found in Linear Settings → Team → API
LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Linear workflow state IDs for your team
# Run: .claude/hooks/linear-get-states.ps1 to find these
LINEAR_IN_PROGRESS_STATE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LINEAR_IN_REVIEW_STATE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
