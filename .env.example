# XPredict env template — copy to `.env.local` and fill in.
#
# `.env.local` is gitignored (D-32, PLT-03). This file (`.env.example`) is
# committed and contains placeholders only — never real secrets.
#
# The GitHub MCP token does NOT go here: `GITHUB_PERSONAL_ACCESS_TOKEN` is a
# Claude Code / OS environment variable (set via `setx` or
# `~/.claude/settings.local.json` "env"), read by `.mcp.json` — not by this
# file.

# ---------------------------------------------------------------------------
# Phase 1 — Backend (D-09, D-32, PLT-03)
# ---------------------------------------------------------------------------

ENVIRONMENT=dev
LOG_LEVEL=INFO

# DB / Redis (host-mode URLs — docker-compose overrides these to db:5432 etc.
# via service-level `environment:` blocks).
DATABASE_URL=postgresql+asyncpg://xpredict:xpredict@localhost:5432/xpredict
DATABASE_URL_SYNC=postgresql+psycopg2://xpredict:xpredict@localhost:5432/xpredict
REDIS_URL=redis://localhost:6379/0

# Sentry — optional in dev. Leave empty to disable Sentry init (Pattern 5a
# `init_sentry` no-ops when DSN is unset).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Phase 1 — Frontend (D-14)
# ---------------------------------------------------------------------------

# `NEXT_PUBLIC_` prefix exposes to the client bundle (required by Next.js).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_API_URL=http://localhost:8000

# Browser-readable WebSocket base for live market price updates (Phase 9 /
# MKT-04). Read in the `use-market-socket` "use client" hook, so it MUST be
# `NEXT_PUBLIC_`-prefixed (the server-only BACKEND_URL is never bundled into
# the client). Use `wss://` (TLS) in production. Non-secret — it is the public
# API host with a `ws://`/`wss://` scheme.
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Server-only URL used by Next.js Server Actions to reach the FastAPI backend.
# No `NEXT_PUBLIC_` prefix — never bundled into the client (T-02-39 mitigation).
BACKEND_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Demo mode (sales-demo toggle — relaxes auth)
# ---------------------------------------------------------------------------
#
# DEMO_MODE turns sign-up into a frictionless sales-demo flow: 6-char
# passwords, auto-verified email (no inbox round-trip), an instant signup
# wallet bonus, and an email+password-only register form. The dev/demo
# docker-compose defaults BOTH vars to true, so the local stack is the demo
# out of the box. Set BOTH to false for production-grade auth (>=12-char
# passwords + email verification).
#   - DEMO_MODE             -> backend  (app/core/config.py, app/auth/manager.py)
#   - NEXT_PUBLIC_DEMO_MODE -> frontend (register form + client-side pw rule)
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# ---------------------------------------------------------------------------
# Linear (optional — collaboration infra, gitignored when populated)
# ---------------------------------------------------------------------------
#
# Linear is OPTIONAL — the only value you may need is your personal API key.
# Without it, the Linear hooks skip cleanly. Shared non-secret team/state IDs
# are already committed in `.claude/linear.shared.env` — do NOT duplicate
# them here.
#
# Personal Linear API key — create at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# ---------------------------------------------------------------------------
# Phase 2 — Auth & Identity (AUTH-01..09, D-09 / D-11 / RESEARCH §Runtime State)
# ---------------------------------------------------------------------------
#
# SECRET_KEY must be at least 32 chars (HS256 needs 256-bit entropy). Generate
# in dev with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# In production, store in a real secret manager — never commit the real value.
SECRET_KEY=change-me-32+chars-of-random-secret
JWT_ALGORITHM=HS256

# Token lifetimes (seconds). 15 min access / 30 day refresh.
ACCESS_TOKEN_LIFETIME_SECONDS=900
REFRESH_TOKEN_LIFETIME_SECONDS=2592000

# Resend (https://resend.com) — staging/prod transactional email.
# Leave empty in dev; the EmailService falls back to Mailpit on SMTP_HOST:SMTP_PORT.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@xpredict.local

# Mailpit (dev SMTP — see docker-compose.yml mailpit service).
SMTP_HOST=mailpit
SMTP_PORT=1025

# First-admin seeding (run `uv run python bin/create-admin.py` once after migrate).
# Password placeholder is intentionally non-secret-shaped so gitleaks stays clean.
FIRST_ADMIN_EMAIL=admin@xpredict.local
FIRST_ADMIN_PASSWORD=change-me-min-12-chars-A1!

# Frontend URL for email links (verify / reset).
FRONTEND_BASE_URL=http://localhost:3000

# Symmetric HS256 secret exposed to Next.js middleware to verify the admin Bearer.
# Must equal backend SECRET_KEY for HS256 verification to succeed (Assumption A8;
# Phase 11 will move to RS256 with asymmetric keys). If this drifts from the
# backend, the Next.js middleware fails closed (every admin request redirects to
# /admin/login) while the backend's current_active_admin still accepts the token
# — verified by middleware.test.ts::redirects_on_invalid_jwt_signature.
ADMIN_JWT_PUBLIC_SECRET=change-me-32+chars-must-match-backend-SECRET_KEY

# ---------------------------------------------------------------------------
# Live-bets demo (v1.3, LB-A)
# ---------------------------------------------------------------------------
#
# Operator-plane keys for the live-bets API bridge (app/integrations/livebets).
# Placeholders only — never a real key (the live-bets sandbox key is shown once
# at /onboard/success and looks like `lbk_sandbox_<48 hex>`).

# Base URL of the live-bets API. Default is the demo port-remapped local stack
# (live-bets's docker-compose maps host :8001 -> container :8000, avoiding the
# :8000 clash with the XPredict backend; Postgres :15432, Redis :6381).
LIVEBETS_API_BASE=http://localhost:8001
# Operator X-API-Key. Needs scopes `catalog:read` + `bets:read` (provisioned in
# LB-C). Leave blank in dev/test; the client raises a clear error if used unset.
LIVEBETS_API_KEY=lbk_sandbox_...
# UUID of the demo table (from `GET /v2/catalog/tables`); used as the session default.
LIVEBETS_DEFAULT_TABLE_ID=
# Webhook backstop is OFF for the demo (DOM events + server-side verification only).
LIVEBETS_ENABLE_WEBHOOK=false
# Only needed if the webhook backstop is enabled (HMAC verify secret).
LIVEBETS_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Casino demo (SlotsLaunch) — quick task 260611-u0q
# ---------------------------------------------------------------------------
#
# SlotsLaunch demo-slots catalog proxy. The token is DOMAIN-BOUND to
# SLOTSLAUNCH_ORIGIN (https://app.xprediction.online) — it is already set in the
# gitignored .env.local; leave it BLANK here (placeholder only, never a real
# secret). With the token blank/unset the /casino surface degrades to the
# friendly "not available yet" empty state; activating the free SlotsLaunch plan
# lights up the grid with zero code changes.
SLOTSLAUNCH_TOKEN=
# ---------------------------------------------------------------------------
