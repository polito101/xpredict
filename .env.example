# XPredict env template — copy to `.env.local` and fill in.
#
# `.env.local` is gitignored (D-32, PLT-03). This file (`.env.example`) is
# committed and contains placeholders only — never real secrets.
#
# The GitHub MCP token does NOT go here: `GITHUB_PERSONAL_ACCESS_TOKEN` is a
# Claude Code / OS environment variable (set via `setx` or
# `~/.claude/settings.local.json` "env"), read by `.mcp.json` — not by this
# file.

# ---------------------------------------------------------------------------
# Phase 1 — Backend (D-09, D-32, PLT-03)
# ---------------------------------------------------------------------------

ENVIRONMENT=dev
LOG_LEVEL=INFO

# DB / Redis (host-mode URLs — docker-compose overrides these to db:5432 etc.
# via service-level `environment:` blocks).
DATABASE_URL=postgresql+asyncpg://xpredict:xpredict@localhost:5432/xpredict
DATABASE_URL_SYNC=postgresql+psycopg2://xpredict:xpredict@localhost:5432/xpredict
REDIS_URL=redis://localhost:6379/0

# Sentry — optional in dev. Leave empty to disable Sentry init (Pattern 5a
# `init_sentry` no-ops when DSN is unset).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Phase 1 — Frontend (D-14)
# ---------------------------------------------------------------------------

# `NEXT_PUBLIC_` prefix exposes to the client bundle (required by Next.js).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Linear (optional — collaboration infra, gitignored when populated)
# ---------------------------------------------------------------------------
#
# Linear is OPTIONAL — the only value you may need is your personal API key.
# Without it, the Linear hooks skip cleanly. Shared non-secret team/state IDs
# are already committed in `.claude/linear.shared.env` — do NOT duplicate
# them here.
#
# Personal Linear API key — create at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# ---------------------------------------------------------------------------
# Phase 2+ will append (do not set in Phase 1):
#   SESSION_SIGNING_KEY=
#   ADMIN_TOKEN=
# ---------------------------------------------------------------------------
