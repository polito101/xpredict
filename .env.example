# XPredict env template — copy to `.env.local` and fill in.
#
# `.env.local` is gitignored (D-32, PLT-03). This file (`.env.example`) is
# committed and contains placeholders only — never real secrets.
#
# The GitHub MCP token does NOT go here: `GITHUB_PERSONAL_ACCESS_TOKEN` is a
# Claude Code / OS environment variable (set via `setx` or
# `~/.claude/settings.local.json` "env"), read by `.mcp.json` — not by this
# file.

# ---------------------------------------------------------------------------
# Phase 1 — Backend (D-09, D-32, PLT-03)
# ---------------------------------------------------------------------------

ENVIRONMENT=dev
LOG_LEVEL=INFO

# DB / Redis (host-mode URLs — docker-compose overrides these to db:5432 etc.
# via service-level `environment:` blocks).
DATABASE_URL=postgresql+asyncpg://xpredict:xpredict@localhost:5432/xpredict
DATABASE_URL_SYNC=postgresql+psycopg2://xpredict:xpredict@localhost:5432/xpredict
REDIS_URL=redis://localhost:6379/0

# Sentry — optional in dev. Leave empty to disable Sentry init (Pattern 5a
# `init_sentry` no-ops when DSN is unset).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Phase 1 — Frontend (D-14)
# ---------------------------------------------------------------------------

# `NEXT_PUBLIC_` prefix exposes to the client bundle (required by Next.js).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Linear (optional — collaboration infra, gitignored when populated)
# ---------------------------------------------------------------------------
#
# Linear is OPTIONAL — the only value you may need is your personal API key.
# Without it, the Linear hooks skip cleanly. Shared non-secret team/state IDs
# are already committed in `.claude/linear.shared.env` — do NOT duplicate
# them here.
#
# Personal Linear API key — create at: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# ---------------------------------------------------------------------------
# Phase 2 — Auth & Identity (AUTH-01..09, D-09 / D-11 / RESEARCH §Runtime State)
# ---------------------------------------------------------------------------
#
# SECRET_KEY must be at least 32 chars (HS256 needs 256-bit entropy). Generate
# in dev with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# In production, store in a real secret manager — never commit the real value.
SECRET_KEY=change-me-32+chars-of-random-secret
JWT_ALGORITHM=HS256

# Token lifetimes (seconds). 15 min access / 30 day refresh.
ACCESS_TOKEN_LIFETIME_SECONDS=900
REFRESH_TOKEN_LIFETIME_SECONDS=2592000

# Resend (https://resend.com) — staging/prod transactional email.
# Leave empty in dev; the EmailService falls back to Mailpit on SMTP_HOST:SMTP_PORT.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@xpredict.local

# Mailpit (dev SMTP — see docker-compose.yml mailpit service).
SMTP_HOST=mailpit
SMTP_PORT=1025

# First-admin seeding (run `uv run python bin/create-admin.py` once after migrate).
# Password placeholder is intentionally non-secret-shaped so gitleaks stays clean.
FIRST_ADMIN_EMAIL=admin@xpredict.local
FIRST_ADMIN_PASSWORD=change-me-min-12-chars-A1!

# Frontend URL for email links (verify / reset).
FRONTEND_BASE_URL=http://localhost:3000

# Symmetric HS256 secret exposed to Next.js middleware to verify admin Bearer.
# In v1 this equals SECRET_KEY (A8); Phase 11 may split to RS256 (pub/priv).
ADMIN_JWT_PUBLIC_SECRET=change-me-32+chars-of-random-secret
# ---------------------------------------------------------------------------
