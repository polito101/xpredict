# XPredict — PRODUCTION demo env template (Hetzner single-VM deploy).
#
# Copy to `.env.prod` (gitignored) on the VM and fill in. Used by:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml ...
#
# NEVER commit `.env.prod`. Generate secrets on the VM, e.g.:
#   openssl rand -base64 36   (use for POSTGRES_PASSWORD)
#   openssl rand -base64 48   (use for SECRET_KEY — must be >= 32 chars)

# ---------------------------------------------------------------------------
# Domains & TLS  (all subdomains need DNS A records → the VM's public IP)
# ---------------------------------------------------------------------------
APP_DOMAIN=app.your-domain.com
API_DOMAIN=api.your-domain.com
# live-bets subdomain (A-record -> the VM's static IP, same as app/api). Caddy
# auto-provisions its TLS cert.
LIVEBETS_DOMAIN=live.your-domain.com
# Email for the Let's Encrypt account (cert-expiry notices). A real inbox.
ACME_EMAIL=you@your-domain.com

# ---------------------------------------------------------------------------
# Public URLs the BROWSER uses  (baked into the frontend bundle at build time)
# ---------------------------------------------------------------------------
# Must match the subdomains above, with scheme. NO trailing slash.
NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com

# CRITICAL: FRONTEND_BASE_URL must EXACTLY equal the frontend origin the browser
# sends (scheme + host, NO trailing slash, NO path). The backend compares the
# browser's Origin header against this for BOTH CORS and the live-price WebSocket
# Origin allow-list — if it drifts (e.g. trailing slash, http vs https, www),
# the WebSocket handshake is rejected (code 1008) and the live feed stays dark.
FRONTEND_BASE_URL=https://app.your-domain.com

# ---------------------------------------------------------------------------
# Secrets  (generate fresh on the VM — never reuse the dev placeholders)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me-strong-random

# SECRET_KEY is the backend's signing/verification secret (>= 32 chars). Generate
# it fresh on the VM. ADMIN_JWT_PUBLIC_SECRET is currently UNUSED by the frontend
# (the Next.js edge gate checks the admin_jwt cookie's PRESENCE only; the real
# admin gate is the backend, keyed on SECRET_KEY) — set it equal to SECRET_KEY as
# a harmless forward-compat default, or leave it blank. It is NOT load-bearing today.
SECRET_KEY=change-me-32+chars-of-random-secret
ADMIN_JWT_PUBLIC_SECRET=change-me-32+chars-same-as-SECRET_KEY

# First admin (seeded once by bin/create_admin.py). Use a real strong password —
# this logs into /admin during the demo.
FIRST_ADMIN_EMAIL=admin@your-domain.com
FIRST_ADMIN_PASSWORD=change-me-min-12-chars-A1!

# Player economy — sign-up bonus credited to a wallet on email verification (play
# money). Defaults to 1000 in app config; override per-deploy (e.g. 10000 for a demo).
SIGNUP_BONUS_AMOUNT=1000.0000

# DEMO_MODE — frictionless sales-demo sign-up: 6-char passwords (no complexity),
# accounts auto-verified at registration, and the sign-up bonus granted immediately
# (no email step). Set BOTH the backend flag (DEMO_MODE) and the frontend build arg
# (NEXT_PUBLIC_DEMO_MODE) so client + server agree. Leave false for production.
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

# ----------------------------------------------------------------------------
# live-bets (co-located v1.3 service) — its own Postgres + signing secrets.
# ----------------------------------------------------------------------------
# Where the live-bets repo is cloned on the VM (compose build context, relative
# to this repo). Default ../live-bets is correct if you clone it next to xpredict.
LIVEBETS_BUILD_CONTEXT=../live-bets
# live-bets Postgres password (generate: openssl rand -hex 24).
LIVEBETS_DB_PASSWORD=
# live-bets request-signing key, MUST be >=32 chars (generate: openssl rand -hex 32).
# Booting with the dev placeholder FAILS FAST when LIVE_BETS_ENV=prod.
LIVE_BETS_SERVER_KEY=
LIVE_BETS_SERVER_KEY_ID=prod-v1
# live-bets admin password as an argon2id hash (required in prod). Generate e.g.:
#   docker run --rm python:3.12-slim sh -c "pip -q install argon2-cffi && \
#     python -c \"from argon2 import PasswordHasher as P; print(P().hash('YOUR_ADMIN_PW'))\""
LIVE_BETS_ADMIN_PASSWORD=
# --- Bridge wiring (XPredict backend -> live-bets, internal network) ---
# Operator API key (full scope). Filled AFTER `bootstrap-admin-key` on the VM (runbook).
LIVEBETS_API_KEY=
# The seeded ACTIVE table id. Filled AFTER seeding the demo table (runbook).
LIVEBETS_DEFAULT_TABLE_ID=
# Internal service URL — rarely overridden.
LIVEBETS_API_BASE=http://livebets:8000
LIVEBETS_ENABLE_WEBHOOK=false

# ---------------------------------------------------------------------------
# Optional — leave blank to disable
# ---------------------------------------------------------------------------
# Sentry (error monitoring). Backend DSN + the browser DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Resend (transactional email: verify / password-reset). Not needed for a
# seeded click-through demo (the seeded admin + users are already verified).
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@your-domain.com

# Live-bets widget (v1.3 /live demo). Served by the co-located live-bets behind
# Caddy at the live subdomain. NEXT_PUBLIC_* is baked at frontend BUILD time, so
# changing this requires a frontend rebuild.
NEXT_PUBLIC_LIVEBETS_WIDGET_SRC=https://live.your-domain.com/static/widget.js
