# Secrets — never commit
.env.local
.env
*.env
# ...except the shared, non-secret Linear IDs (team + workflow states)
!.claude/linear.shared.env

# Linear issue-id markers (per-phase, local)
.planning/phases/*/.linear-issue-id

# Dependencies / build output (preventive — product scaffold lands in Phase 1)
node_modules/
.next/
dist/
build/
__pycache__/

# Vercel local project link (created by `vercel link`) — never commit
.vercel/
.venv/
*.log
.DS_Store

# Python tooling caches
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
