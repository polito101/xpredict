# Backend (FastAPI) — copy to backend/.env for local (non-docker) runs.
# In docker-compose these are provided by the compose file / root .env.

ENVIRONMENT=development
DEBUG=true

# Async driver (asyncpg) for the app; Alembic derives the sync (psycopg) URL.
DATABASE_URL=postgresql+asyncpg://xpredict:xpredict@localhost:5432/xpredict

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000
